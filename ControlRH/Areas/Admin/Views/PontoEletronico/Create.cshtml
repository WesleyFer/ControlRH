@model PontoEletronicoViewModel

@{
    Layout = "~/Views/Shared/_LayoutColaborador.cshtml";
    ViewData["Title"] = "Nova Marcação Ponto";
}

<style>
    body {
        background-color: #f2f7fc;
        font-family: Arial, sans-serif;
    }

    .top-bar {
        background-color: #0ead63;
        color: white;
        font-size: 0.9rem;
        padding: 0.3rem 1rem;
        text-align: center;
    }

    .card-container {
        max-width: 400px;
        margin: 1rem auto;
        padding: 1rem;
    }

    .time-display {
        font-size: 2.5rem;
        font-weight: bold;
    }

    .btn-rounded {
        border-radius: 25px;
        padding: 0.75rem 1.5rem;
    }

    .bottom-box {
        background-color: #e8f6ed;
        border-left: 5px solid #0ead63;
        padding: 0.75rem;
        margin-top: 1rem;
    }
</style>

<div class="card shadow">
    <div class="card-body">

        <div class="row mb-3">
            <div class="col-3"></div>
            <div class="col-6">
                <div class="top-bar">
                    Última sincronização: 07/07/2025 às 21:01
                </div>


                <div class="card-container text-center">

                    <p class="mb-1">Quarta-feira</p>
                    <h6 class="mb-0">09 de Julho de 2025</h6>
                    <div class="time-display my-3">13:01</div>

                    <div class="d-grid gap-2 col-10 mx-auto my-4">
                        @* <button class="btn btn-primary btn-rounded">Registrar ponto</button> 
                        <button class="btn btn-outline-info btn-rounded">Reg. ocorrência</button>
                        *@
                        <button class="btn btn-primary btn-rounded" data-bs-toggle="modal" data-bs-target="#registroModal">
                            Registrar ponto
                        </button>

                        <button class="btn btn-outline-info btn-rounded" data-bs-toggle="modal" data-bs-target="#ocorrenciaModal">
                            Reg. ocorrência
                        </button>
                    </div>

                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title">Cartão de Ponto</h6>
                            <p class="text-muted mb-0">Nenhum cartão disponível</p>
                        </div>
                    </div>

                    <div class="bottom-box text-start">
                        <small class="text-muted">Hoje 13:01 GMT-03:00 via Web</small><br>
                        <span class="fw-semibold text-success">📍 Av. Copacabana, 238 - 4º andar - Empresarial 18 do Forte / Alphaville, Barueri - SP - 06472-001, Brasil</span>
                    </div>
                </div>
            </div>
            <div class="col-3"></div>
        </div>

        <form asp-area="Admin" asp-controller="PontoEletronico" asp-action="Create" method="post">

            @Html.AntiForgeryToken()

        </form>
    </div>
</div>

<!-- Modal para autenticação -->
<div class="modal fade" id="registroModal" tabindex="-1" aria-labelledby="registroModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form>
                <div class="modal-header">
                    <h5 class="modal-title" id="registroModalLabel">Autenticação</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="cpf" class="form-label">CPF</label>
                        <input type="text" class="form-control" id="cpf" placeholder="000.000.000-00" required>
                    </div>
                    <div class="mb-3">
                        <label for="senha" class="form-label">Senha</label>
                        <input type="password" class="form-control" id="senha" placeholder="Senha" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Registrar Ponto</button>
                </div>
            </form>
        </div>
    </div>
</div>


<!-- Modal de Registro de Ocorrência -->
<div class="modal fade" id="ocorrenciaModal" tabindex="-1" aria-labelledby="ocorrenciaModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form>
                <div class="modal-header">
                    <h5 class="modal-title" id="ocorrenciaModalLabel">Registrar Ocorrência</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="cpfOcorrencia" class="form-label">CPF</label>
                        <input type="text" class="form-control" id="cpfOcorrencia" required>
                    </div>
                    <div class="mb-3">
                        <label for="senhaOcorrencia" class="form-label">Senha</label>
                        <input type="password" class="form-control" id="senhaOcorrencia" required>
                    </div>
                    <div class="mb-3">
                        <label for="horarioCorreto" class="form-label">Horário Correto</label>
                        <input type="datetime-local" class="form-control" id="horarioCorreto" required>
                    </div>
                    <div class="mb-3">
                        <label for="justificativa" class="form-label">Justificativa</label>
                        <textarea class="form-control" id="justificativa" rows="3" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-info">Enviar Ocorrência</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.PontoEletronico.init();
    </script>
}

